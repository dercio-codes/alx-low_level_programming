#include "main.h"
/**
 * factorial - Prints a factorial of number.
 * @n: The string to be printed.
 */int factorial(int n) {
  if (n < 0) {
    return -1;
  } else if (n == 0) {
    return 1;
  } else {
    int factorial = 1;
    for (int i = 1; i <= n; i++) {
      factorial *= i;
    }
    return factorial;
  }
}
